# Backend (Express) environment — the ONLY service that holds DB credentials.
# Copy to server/.env and fill in. Local dev points at the Dockerized Postgres
# published on host port 5433 (see docker-compose.yml).
DATABASE_URL="postgresql://bookit_user:bookit_pass@localhost:5433/bookit_db?schema=public"

# MUST match the frontend's NEXTAUTH_SECRET — the Next edge mints short-lived
# JWTs that this backend verifies with the same secret. Use a long random string.
AUTH_SECRET="change-me-to-a-long-random-string"

PORT=4000
