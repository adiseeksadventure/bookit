# Frontend (Next.js edge) environment. Holds NO database credentials — it
# forwards every /api/* call to the Express backend and only manages Auth.js
# sessions. Copy to .env. (DATABASE_URL lives in server/.env.)

# Base URL of the Express backend the proxy forwards to.
BACKEND_URL="http://localhost:4000"

# Auth.js session signing. MUST match the backend's AUTH_SECRET. Long random string.
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
